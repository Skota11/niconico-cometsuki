{
    "manifest_version": 3,
    "name": "Niconico | ニコニココメ付き保存",
    "version": "1.3",
    "description": "コメント付きのニコニコ動画とニコニコ生放送の録画が出来ます。",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Niconico Recorder"
    },
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "downloads",
        "notifications",
        "contextMenus",
        "tabs"
    ],
    "host_permissions": [
        "*://*.nicovideo.jp/*",
        "*://*.live.nicovideo.jp/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "recording_ui.html",
                "icons/*"
            ],
            "matches": [
                "*://*.nicovideo.jp/*",
                "*://*.live.nicovideo.jp/*"
            ]
        }
    ],
    "commands": {
        "_execute_action": {
            "suggested_key": {
                "default": "Ctrl+Shift+Y",
                "mac": "Command+Shift+Y"
            },
            "description": "Open popup"
        },
        "toggle-recording": {
            "suggested_key": {
                "default": "Ctrl+Shift+R",
                "mac": "Command+Shift+R"
            },
            "description": "Start/stop recording on current tab"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}